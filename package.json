{
  "name": "senior-rides",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:rider": "npm --workspace @senior-rides/rider-app run start",
    "start:driver": "npm --workspace @senior-rides/driver-app run start",
    "start:admin": "npm --workspace @senior-rides/admin-app run start",
    "start:rider:dev": "npm --workspace @senior-rides/rider-app run start -- --dev-client --clear",
    "start:driver:dev": "npm --workspace @senior-rides/driver-app run start -- --dev-client --clear",
    "start:admin:dev": "npm --workspace @senior-rides/admin-app run start -- --dev-client --clear",
    "start:rider:dev:tunnel": "npm --workspace @senior-rides/rider-app run start -- --dev-client --tunnel --clear",
    "start:driver:dev:tunnel": "npm --workspace @senior-rides/driver-app run start -- --dev-client --tunnel --clear",
    "start:admin:dev:tunnel": "npm --workspace @senior-rides/admin-app run start -- --dev-client --tunnel --clear",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "doctor:rider": "npm --workspace @senior-rides/rider-app exec expo-doctor",
    "doctor:driver": "npm --workspace @senior-rides/driver-app exec expo-doctor",
    "doctor:admin": "npm --workspace @senior-rides/admin-app exec expo-doctor"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
