{
  "name": "senior-rides",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:rider": "npm --workspace @senior-rides/rider-app run start",
    "start:driver": "npm --workspace @senior-rides/driver-app run start",
    "start:admin": "npm --workspace @senior-rides/admin-app run start",
    "start:rider:tunnel": "npm --workspace @senior-rides/rider-app run start -- --tunnel",
    "start:driver:tunnel": "npm --workspace @senior-rides/driver-app run start -- --tunnel",
    "start:admin:tunnel": "npm --workspace @senior-rides/admin-app run start -- --tunnel",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/metro-runtime": "56.0.16",
    "expo": "56.0.14",
    "expo-constants": "56.0.20",
    "expo-font": "56.0.7",
    "expo-linking": "56.0.15",
    "expo-router": "56.2.13",
    "expo-status-bar": "56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2",
    "typescript": "6.0.3"
  },
  "overrides": {
    "@expo/metro-runtime": "56.0.16",
    "expo": "56.0.14",
    "expo-constants": "56.0.20",
    "expo-font": "56.0.7",
    "expo-linking": "56.0.15",
    "expo-status-bar": "56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
